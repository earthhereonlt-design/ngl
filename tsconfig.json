{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022"
    ],
    "skipLibCheck": true,
    "moduleResolution": "node",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  }
}
